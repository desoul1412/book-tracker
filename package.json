{
  "name": "ceo-simulator-tmp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "server:bundle": "esbuild server/index.ts --bundle --platform=node --external:better-sqlite3 --external:sqlite-vec --external:@anthropic-ai/claude-agent-sdk --outfile=src-tauri/binaries/node-server.mjs --format=esm && node scripts/copy-sdk-cli.mjs",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "sidecar:build:win": "node scripts/build-sidecar.mjs --target win-x64",
    "sidecar:build:mac": "node scripts/build-sidecar.mjs --target mac-arm64",
    "release:win": "npm run sidecar:build:win && npm run build && node scripts/tauri-run.mjs build",
    "release:mac": "npm run sidecar:build:mac && npm run build && node scripts/tauri-run.mjs build",
    "updater:keygen": "node scripts/tauri-run.mjs signer generate --ci",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:api": "npx playwright test e2e/07-api-health.spec.ts",
    "test:e2e:pipeline": "npx playwright test e2e/09-planning-execution-flow.spec.ts --headed",
    "test:all": "vitest run && npx playwright test",
    "sb:start": "npx supabase start",
    "sb:stop": "npx supabase stop",
    "sb:reset": "npx supabase db reset",
    "sb:diff": "npx supabase db diff --use-migra",
    "sb:push": "npx supabase db push",
    "sb:types": "npx supabase gen types typescript --project-id qdhengvarelfdtmycnti --schema public > src/types/supabase.ts",
    "sb:functions:serve": "npx supabase functions serve",
    "sb:functions:deploy": "npx supabase functions deploy",
    "sb:link": "npx supabase link --project-ref qdhengvarelfdtmycnti"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.96",
    "@hookform/resolvers": "^5.2.2",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "sqlite-vec": "^0.1.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
